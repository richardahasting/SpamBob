# Copy to .env and fill in your values

# ── Anthropic ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── IMAP server ───────────────────────────────────────────
IMAP_HOST=127.0.0.1
IMAP_PORT=143

# ── Persona IMAP credentials ──────────────────────────────
# Each active persona needs IMAP_USER_<KEY> and IMAP_PASS_<KEY>.
# Comment out personas you don't want active.

# Bob Gaines (richard@hastingtx.org)
IMAP_USER_BOB=richard@hastingtx.org
IMAP_PASS_BOB=your_richard_imap_password

# First Church of Fidelity congregation
IMAP_USER_PASTOR=pastor@firstchurchoffidelity.net
IMAP_PASS_PASTOR=church_password_here

IMAP_USER_SECRETARY=secretary@firstchurchoffidelity.net
IMAP_PASS_SECRETARY=church_password_here

IMAP_USER_HAROLD=harold@firstchurchoffidelity.net
IMAP_PASS_HAROLD=church_password_here

IMAP_USER_RUTHANNE=ruthanne@firstchurchoffidelity.net
IMAP_PASS_RUTHANNE=church_password_here

# ── Timing (hours) ────────────────────────────────────────
FIRST_DELAY_MIN=2
FIRST_DELAY_MAX=8
FOLLOWUP_DELAY_MIN=8
FOLLOWUP_DELAY_MAX=28

# ── Cross-pollination ─────────────────────────────────────
# After this many turns, maybe spawn a second persona
REFERRAL_AFTER_TURNS=3
# Probability (0.0-1.0) that a referral is spawned
REFERRAL_CHANCE=0.6

# ── Limits ────────────────────────────────────────────────
MAX_TURNS=25
ABANDON_DAYS=14

# ── Poll interval (seconds) ───────────────────────────────
CHECK_INTERVAL=600

# ── IMAP folder that Sieve routes scam mail into ──────────
SCAM_FOLDER=Scambaiter
